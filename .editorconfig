root = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 120
insert_final_newline = true
charset = utf-8
ktlint_disabled_rules = no-wildcard-imports, import-ordering, filename, function-naming

[*.kt]
ktlint_function_naming_pattern = ^([A-Z][a-zA-Z0-9]*)|([a-z][a-zA-Z0-9]*)$
